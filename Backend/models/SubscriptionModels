// models/Subscription.js
const subscriptionSchema = new mongoose.Schema({
  subAdminId: {
    type: mongoose.Schema.Types.ObjectId,
    ref: "SubAdmin",
    required: true
  },
  userId: {
    type: mongoose.Schema.Types.ObjectId,
    ref: "User"
  },
  status: {
    type: String,
    enum: ["active", "inactive", "expired"],
    default: "active"
  },
  createdAt: { type: Date, default: Date.now }
});